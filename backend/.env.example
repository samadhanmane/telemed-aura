# =============================================================================
# Telemed Aura — BACKEND (.env)
# Copy to backend/.env and fill in. Never commit .env
# =============================================================================

# --- Core API ---
NODE_ENV=development
PORT=4000
API_PUBLIC_URL=http://localhost:4000

# Frontend origin (CORS) — must match frontend URL
FRONTEND_URL=http://localhost:5173

# --- Auth / MongoDB ---
JWT_SECRET=
JWT_EXPIRES_IN=7d
MONGODB_URI=
MONGODB_DB_NAME=netmetaura

# --- Internal services (same host in dev; separate URLs on AWS) ---
EMAIL_SERVICE_URL=http://localhost:4001
AI_SERVICE_URL=http://localhost:4002
VIDEO_SERVICE_URL=http://localhost:4000
SIGNALING_PATH=/signaling
EMAIL_PORT=4001
AI_PORT=4002
VIDEO_PORT=4003

# --- Email (Nodemailer / Gmail) ---
EMAIL=
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- AI ---
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# --- Video / WebRTC (AWS: use coturn on EC2 or managed TURN) ---
SIGNALING_PATH=/signaling
VIDEO_MAX_BITRATE_KBPS=500
VIDEO_MIN_BITRATE_KBPS=150
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
STUN_URL=stun:stun.l.google.com:19302

# --- AWS (production) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_REPORTS=
S3_BUCKET_RECORDINGS=
