# =============================================================================
# Telemed — BACKEND (.env)
# Copy to backend/.env locally. On Render, set these in Environment.
# Never commit .env
# =============================================================================

# --- Core API ---
NODE_ENV=development
PORT=4000
# Public URL of this API (logging / docs; optional locally)
API_PUBLIC_URL=http://localhost:4000

# --- Production (Render) — required for browser access ---
# Exact Vercel frontend URL(s), comma-separated (no trailing slash)
# FRONTEND_URL=https://your-app.vercel.app,https://www.your-domain.com
# API_PUBLIC_URL=https://your-api.onrender.com

# --- Local development ---
# CORS + Socket.IO allowed origins
FRONTEND_URL=http://localhost:8080,http://localhost:8081
# Dev only: also allow localhost:5173|8080|8081 (set FRONTEND_DEV_PORTS=off to disable)
FRONTEND_DEV_PORTS=5173,8080,8081

# --- Auth / MongoDB ---
JWT_SECRET=
JWT_EXPIRES_IN=7d
# Atlas SRV (default): mongodb+srv://USER:PASS@cluster….mongodb.net
# Restricted networks: use Atlas "Standard" URI → mongodb://USER:PASS@host.mongodb.net:27017/…
# Local only: mongodb://127.0.0.1:27017
MONGODB_URI=
MONGODB_DB_NAME=netmetaura

# --- Platform admin (sign in → /admin dashboard) ---
ADMIN_EMAIL=admin@telemed.local
ADMIN_PASSWORD=
ADMIN_NAME=Platform Admin

# --- Internal services (same host in dev; separate URLs on AWS) ---
EMAIL_SERVICE_URL=http://localhost:4001
AI_SERVICE_URL=http://localhost:4002
VIDEO_SERVICE_URL=http://localhost:4000
SIGNALING_PATH=/signaling
EMAIL_PORT=4001
AI_PORT=4002
VIDEO_PORT=4003

# --- Email (Nodemailer / Gmail) ---
EMAIL=
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- AI (Gemini) ---
AI_PROVIDER=gemini
AI_API_KEY=
# Google AI Studio models (see https://ai.google.dev/gemini-api/docs/models)
AI_MODEL=gemini-2.0-flash-lite
AI_VISION_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
AI_MAX_OCR_CHARS=2800
AI_MAX_VISION_PREVIEW=900
AI_MAX_SYNTHESIS_CHARS=1200
AI_MAX_TOKENS_VISION=512
AI_MAX_TOKENS_SYNTHESIS=384
AI_MAX_TOKENS_RX=512
AI_SKIP_SYNTHESIS_LOW_RISK=true
AI_EMBEDDING_MODEL=text-embedding-004
# Set false to skip Gemini embed API on upload (uses hash vectors; saves quota)
# AI_USE_GEMINI_EMBEDDINGS=false
# Max text chunks embedded per document (default 12)
# AI_MAX_EMBED_CHUNKS_PER_DOC=12
# Log each Gemini call during upload: AI_LOG_GEMINI_CALLS=true
# Max PDF pages to send to Gemini when OCR fails (default 3)
# AI_MAX_GEMINI_PAGES_PER_DOC=3
# Rate limiting (free tier): global queue + spacing between calls
# AI_GEMINI_RPM=5
# AI_GEMINI_MIN_DELAY_MS=1500
# AI_GEMINI_CALLS_PER_UPLOAD=3
# AI_GEMINI_CALLS_PER_CHAT=1
# AI_DISABLE_GEMINI=true
# Hybrid report analysis: rules parse labs; Gemini gives final verdict when rules are weak or
# document mentions cancer, fracture, spine, imaging, etc. Set true to always prefer Gemini narrative.
# AI_GEMINI_PRIMARY_VERDICT=true
# Gemini is also used for: report page/image OCR fallback, Doc Assistant chat answers.
# Prescriptions use Tesseract/pdf-parse only. No synthesis/embeddings by default.
# AI_ENABLE_UPLOAD_SYNTHESIS=true
# RAG extras (off by default; chat uses 1 generate call)
# AI_RAG_REWRITE=true
# AI_RAG_COMPLETENESS=true
# AI_RAG_AUDIT=true

# --- Cloudinary (required for Doc Assistant uploads) ---
# Either naming style works:
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET_KEY=
# Or:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Video / WebRTC (production: TURN required for rural NAT) ---
SIGNALING_PATH=/signaling
VIDEO_MAX_BITRATE_KBPS=500
VIDEO_MIN_BITRATE_KBPS=120
# Start tier: low (240p) | medium (360p) | high — low recommended for villages
VIDEO_START_TIER=low
# Set false to disable automatic audio-only fallback
VIDEO_AUDIO_FALLBACK=true
# STUN (comma-separated OK): stun:stun.l.google.com:19302
STUN_URL=stun:stun.l.google.com:19302
# TURN — use coturn, Twilio NTS, or Xirsys. Both vars accept comma-separated URLs.
# Example coturn: turn:your-server.com:3478?transport=udp,turn:your-server.com:3478?transport=tcp
# WebRTC STUN/TURN (Metered example — use your dashboard credentials)
STUN_URL=stun:stun.relay.metered.ca:80
TURN_URL=turn:global.relay.metered.ca:80,turn:global.relay.metered.ca:80?transport=tcp,turn:global.relay.metered.ca:443,turns:global.relay.metered.ca:443?transport=tcp
TURN_USERNAME=
TURN_CREDENTIAL=

# --- AWS (production) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_REPORTS=
S3_BUCKET_RECORDINGS=
