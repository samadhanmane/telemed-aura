# =============================================================================
# Telemed — FRONTEND (.env)
# Copy to frontend/.env locally. On Vercel, set these in Project → Environment Variables.
# Only VITE_* variables are exposed to the browser.
# =============================================================================

# --- Production (Vercel) — required ---
# Render backend URL + /api/v1 path
# VITE_API_URL=https://your-api.onrender.com/api/v1
# Same host as API (signaling runs on the main backend, not a separate port)
# VITE_VIDEO_SERVICE_URL=https://your-api.onrender.com
# Optional: only needed for SSR/build without window — browser uses current tab origin
# VITE_APP_URL=https://your-app.vercel.app

# --- Local development ---
VITE_API_URL=http://localhost:4000/api/v1
VITE_VIDEO_SERVICE_URL=http://localhost:4000
VITE_VIDEO_SIGNALING_PATH=/signaling
# Optional SSR fallback; in the browser, app URL = current tab (8080 or 8081)
VITE_APP_URL=http://localhost:8080
VITE_VIDEO_DEBUG=false
