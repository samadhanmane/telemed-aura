# =============================================================================
# Telemed Aura — FRONTEND (.env)
# Copy to frontend/.env — only VITE_* vars are exposed to the browser
# =============================================================================

# Main REST API (backend)
VITE_API_URL=http://localhost:4000/api/v1

# Video signaling — SAME host as API (WebRTC runs on main backend port)
# Local dev: http://localhost:4000  |  Production: https://api.yourdomain.com
VITE_VIDEO_SERVICE_URL=http://localhost:4000
VITE_VIDEO_SIGNALING_PATH=/signaling

# Public app URL (links in emails, redirects)
VITE_APP_URL=http://localhost:5173

# Optional: enable debug logs for WebRTC
VITE_VIDEO_DEBUG=false
